# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Source files — always LF
*.js   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env* text eol=lf

# Binary files — no normalization
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
